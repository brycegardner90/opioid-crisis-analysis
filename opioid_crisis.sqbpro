<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="opioid_crisis.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1149"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="demographics" custom_title="0" dock_id="1" table="4,12:maindemographics"/><dock_state state="000000ff00000000fd00000001000000020000000000000000fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000ffffffff0000011800ffffff000000000000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings/></tab_browse><tab_sql><sql name="SQL 1*">SELECT 
    year,
    deaths,
    crude_rate
FROM national_trend
ORDER BY year;
</sql><sql name="SQL 2*">SELECT
    year,
    prescription_opioids,
    heroin,
    synthetic_opioids_fentanyl,
    any_opioid
FROM drug_type
ORDER BY year;</sql><sql name="SQL 3*">SELECT
    state,
    deaths,
    crude_rate
FROM state_totals
ORDER BY crude_rate DESC
LIMIT 10;</sql><sql name="SQL 4*">SELECT
    age_group,
    sex,
    deaths,
    crude_rate
FROM demographics
WHERE age_group NOT IN ('&lt; 1 year', '1-4 years', '5-14 years', 'Not Stated')
ORDER BY age_group, sex;</sql><sql name="SQL 5*">SELECT
    year,
    deaths,
    crude_rate
FROM state_by_year
WHERE state = 'West Virginia'
ORDER BY year;</sql><current_tab id="4"/></tab_sql></sqlb_project>
